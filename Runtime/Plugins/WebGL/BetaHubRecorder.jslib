var BetaHubRecorderLib = {

    $BetaHubRecorder: {
        // State
        canvas: null,
        isRecording: false,
        isPaused: false,
        segments: [],        // Array of { data: ArrayBuffer, mimeType: string }
        segmentIndex: 0,
        method: null,        // 'webcodecs' or 'mediarecorder'
        stopRequested: false,
        initialized: false,

        // Config
        MAX_SEGMENTS: 6,
        SEGMENT_DURATION_MS: 10000,
        TARGET_FPS: 30,

        // mp4-muxer references (set during Init)
        Muxer: null,
        ArrayBufferTarget: null,

        // WebCodecs state
        wcSegment: null,     // { encoder, muxer, target, frameCount, startTime }
        wcReader: null,
        wcTrack: null,
        wcFrameCount: 0,
        wcEncoderError: null,

        // MediaRecorder state
        mrRecorder: null,
        mrStream: null,
        mrRotationTimer: null,
        _finalSegmentPending: false,

        // ---- Helper: detect best recording method ----
        detectMethod: function() {
            if (typeof VideoEncoder !== 'undefined' &&
                typeof MediaStreamTrackProcessor !== 'undefined') {
                return 'webcodecs';
            }
            if (typeof MediaRecorder !== 'undefined') {
                return 'mediarecorder';
            }
            return null;
        },

        // ---- WebCodecs: create fresh encoder+muxer for a segment ----
        createSegmentEncoder: function(width, height) {
            var target = new BetaHubRecorder.ArrayBufferTarget();
            var muxer = new BetaHubRecorder.Muxer({
                target: target,
                video: { codec: 'avc', width: width, height: height },
                fastStart: 'in-memory',
                firstTimestampBehavior: 'offset',
            });

            var encoder = new VideoEncoder({
                output: function(chunk, meta) { muxer.addVideoChunk(chunk, meta); },
                error: function(e) {
                    BetaHubRecorder.wcEncoderError = e.message;
                    console.error('[BetaHubRecorder] Encoder error:', e);
                },
            });

            encoder.configure({
                codec: 'avc1.640028',
                width: width,
                height: height,
                bitrate: 5000000,
                framerate: BetaHubRecorder.TARGET_FPS,
            });

            return {
                encoder: encoder,
                muxer: muxer,
                target: target,
                frameCount: 0,
                startTime: Date.now()
            };
        },

        // ---- WebCodecs: finalize current segment ----
        finalizeCurrentSegment: function() {
            var seg = BetaHubRecorder.wcSegment;
            if (!seg || seg.frameCount === 0) {
                return Promise.resolve();
            }

            var doFinalize = function() {
                seg.muxer.finalize();
                var buffer = seg.target.buffer;
                BetaHubRecorder.segments.push({
                    data: buffer,
                    mimeType: 'video/mp4',
                });
                BetaHubRecorder.segmentIndex++;

                // Rolling window
                if (BetaHubRecorder.segments.length > BetaHubRecorder.MAX_SEGMENTS) {
                    BetaHubRecorder.segments.shift();
                }
            };

            if (seg.encoder.state === 'configured') {
                return seg.encoder.flush().then(function() {
                    seg.encoder.close();
                    doFinalize();
                });
            } else {
                doFinalize();
                return Promise.resolve();
            }
        },

        // ---- WebCodecs: rotate to new segment ----
        rotateWebCodecsSegment: function(width, height) {
            return BetaHubRecorder.finalizeCurrentSegment().then(function() {
                BetaHubRecorder.wcSegment = BetaHubRecorder.createSegmentEncoder(width, height);
            });
        },

        // ---- WebCodecs: main recording loop (async, fire-and-forget) ----
        startWebCodecs: function() {
            var stream = BetaHubRecorder.canvas.captureStream(BetaHubRecorder.TARGET_FPS);
            BetaHubRecorder.wcTrack = stream.getVideoTracks()[0];
            var settings = BetaHubRecorder.wcTrack.getSettings();
            var width = settings.width || BetaHubRecorder.canvas.width || 960;
            var height = settings.height || BetaHubRecorder.canvas.height || 600;

            // Ensure dimensions are even (encoder requirement)
            width = width - (width % 2);
            height = height - (height % 2);

            BetaHubRecorder.wcEncoderError = null;
            BetaHubRecorder.wcFrameCount = 0;
            BetaHubRecorder.stopRequested = false;

            // Create first segment encoder+muxer
            BetaHubRecorder.wcSegment = BetaHubRecorder.createSegmentEncoder(width, height);

            var processor = new MediaStreamTrackProcessor({ track: BetaHubRecorder.wcTrack });
            BetaHubRecorder.wcReader = processor.readable.getReader();

            var readLoop = function() {
                if (BetaHubRecorder.stopRequested || BetaHubRecorder.wcEncoderError) {
                    // Finalize last segment and clean up
                    return BetaHubRecorder.finalizeCurrentSegment().then(function() {
                        BetaHubRecorder.wcReader.cancel().catch(function() {});
                        BetaHubRecorder.wcTrack.stop();
                        BetaHubRecorder.wcSegment = null;
                        BetaHubRecorder.isRecording = false;
                        console.log('[BetaHubRecorder] WebCodecs recording stopped. Segments: ' + BetaHubRecorder.segments.length);
                    });
                }

                return BetaHubRecorder.wcReader.read().then(function(result) {
                    if (result.done) {
                        return BetaHubRecorder.finalizeCurrentSegment().then(function() {
                            BetaHubRecorder.wcReader.cancel().catch(function() {});
                            BetaHubRecorder.wcTrack.stop();
                            BetaHubRecorder.wcSegment = null;
                            BetaHubRecorder.isRecording = false;
                        });
                    }

                    var frame = result.value;

                    if (BetaHubRecorder.isPaused) {
                        frame.close();
                        return readLoop();
                    }

                    if (BetaHubRecorder.wcSegment && BetaHubRecorder.wcSegment.encoder.state === 'configured') {
                        var keyFrame = BetaHubRecorder.wcSegment.frameCount % 60 === 0;
                        BetaHubRecorder.wcSegment.encoder.encode(frame, { keyFrame: keyFrame });
                        BetaHubRecorder.wcSegment.frameCount++;
                        BetaHubRecorder.wcFrameCount++;
                    }
                    frame.close();

                    // Check if segment rotation needed
                    if (BetaHubRecorder.wcSegment &&
                        Date.now() - BetaHubRecorder.wcSegment.startTime >= BetaHubRecorder.SEGMENT_DURATION_MS) {
                        return BetaHubRecorder.rotateWebCodecsSegment(width, height).then(readLoop);
                    }

                    return readLoop();
                });
            };

            // Fire-and-forget the async loop
            readLoop().catch(function(e) {
                console.error('[BetaHubRecorder] WebCodecs loop error:', e);
                BetaHubRecorder.isRecording = false;
            });
        },

        // ---- MediaRecorder: start a new segment recorder ----
        startMediaRecorderSegment: function() {
            var mimeType = 'video/webm; codecs=vp9';
            if (!MediaRecorder.isTypeSupported(mimeType)) {
                mimeType = 'video/webm; codecs=vp8';
            }

            BetaHubRecorder.mrRecorder = new MediaRecorder(BetaHubRecorder.mrStream, {
                mimeType: mimeType,
                videoBitsPerSecond: 5000000,
            });

            var chunks = [];
            BetaHubRecorder.mrRecorder.ondataavailable = function(e) {
                if (e.data.size > 0) chunks.push(e.data);
            };

            BetaHubRecorder.mrRecorder.onstop = function() {
                var blob = new Blob(chunks, { type: mimeType });
                var done = function() {
                    if (BetaHubRecorder._finalSegmentPending) {
                        BetaHubRecorder._finalSegmentPending = false;
                        BetaHubRecorder.isRecording = false;
                        console.log('[BetaHubRecorder] MediaRecorder stopped. Segments: ' + BetaHubRecorder.segments.length);
                    }
                };
                if (blob.size > 0) {
                    blob.arrayBuffer().then(function(buffer) {
                        BetaHubRecorder.segments.push({
                            data: buffer,
                            mimeType: mimeType.split(';')[0].trim(), // 'video/webm'
                        });
                        BetaHubRecorder.segmentIndex++;

                        if (BetaHubRecorder.segments.length > BetaHubRecorder.MAX_SEGMENTS) {
                            BetaHubRecorder.segments.shift();
                        }
                        done();
                    });
                } else {
                    done();
                }
            };

            BetaHubRecorder.mrRecorder.start(1000);
        },

        // ---- MediaRecorder: rotate segment ----
        rotateMediaRecorderSegment: function() {
            if (BetaHubRecorder.mrRecorder && BetaHubRecorder.mrRecorder.state === 'recording') {
                BetaHubRecorder.mrRecorder.stop();
                BetaHubRecorder.startMediaRecorderSegment();
            }
        },

        // ---- MediaRecorder: start recording ----
        startMediaRecorder: function() {
            BetaHubRecorder.mrStream = BetaHubRecorder.canvas.captureStream(BetaHubRecorder.TARGET_FPS);
            BetaHubRecorder.stopRequested = false;

            BetaHubRecorder.startMediaRecorderSegment();

            BetaHubRecorder.mrRotationTimer = setInterval(function() {
                if (!BetaHubRecorder.stopRequested && !BetaHubRecorder.isPaused) {
                    BetaHubRecorder.rotateMediaRecorderSegment();
                }
            }, BetaHubRecorder.SEGMENT_DURATION_MS);
        },

        // ---- MediaRecorder: stop recording ----
        stopMediaRecorder: function() {
            if (BetaHubRecorder.mrRotationTimer) {
                clearInterval(BetaHubRecorder.mrRotationTimer);
                BetaHubRecorder.mrRotationTimer = null;
            }
            if (BetaHubRecorder.mrRecorder && BetaHubRecorder.mrRecorder.state !== 'inactive') {
                // Signal that the onstop handler should set isRecording=false
                // after the last segment's blob.arrayBuffer() resolves
                BetaHubRecorder._finalSegmentPending = true;
                BetaHubRecorder.mrRecorder.stop();
                // Safety fallback in case onstop never fires
                setTimeout(function() {
                    if (BetaHubRecorder._finalSegmentPending) {
                        BetaHubRecorder._finalSegmentPending = false;
                        BetaHubRecorder.isRecording = false;
                        console.warn('[BetaHubRecorder] MediaRecorder stop timed out (safety fallback)');
                    }
                }, 5000);
            } else {
                BetaHubRecorder.isRecording = false;
            }
            if (BetaHubRecorder.mrStream) {
                BetaHubRecorder.mrStream.getTracks().forEach(function(t) { t.stop(); });
                BetaHubRecorder.mrStream = null;
            }
        },
    },

    // ==================== Exported functions ====================

    BetaHubRecorder_Init__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_Init: function() {
        if (BetaHubRecorder.initialized) return 1;

        // ---- Load mp4-muxer inline (MIT license, https://github.com/Vanilagy/mp4-muxer) ----
        // BEGIN mp4-muxer v5.1.3 (base64-encoded to bypass Emscripten acorn-optimizer ES6 parse limitation)
        // Source: https://github.com/Vanilagy/mp4-muxer (MIT license)
        var Mp4Muxer = eval(atob(""));
        // END mp4-muxer

        // Store mp4-muxer references
        BetaHubRecorder.Muxer = Mp4Muxer.Muxer;
        BetaHubRecorder.ArrayBufferTarget = Mp4Muxer.ArrayBufferTarget;

        // Get Unity canvas
        BetaHubRecorder.canvas = Module.canvas || document.querySelector('#unity-canvas') || document.querySelector('canvas');
        if (!BetaHubRecorder.canvas) {
            console.error('[BetaHubRecorder] No canvas found');
            return 0;
        }

        // Detect recording method
        BetaHubRecorder.method = BetaHubRecorder.detectMethod();
        if (!BetaHubRecorder.method) {
            console.error('[BetaHubRecorder] No recording method available (need WebCodecs or MediaRecorder)');
            return 0;
        }

        BetaHubRecorder.initialized = true;
        console.log('[BetaHubRecorder] Initialized. Method: ' + BetaHubRecorder.method + ', Canvas: ' + BetaHubRecorder.canvas.width + 'x' + BetaHubRecorder.canvas.height);
        return 1;
    },

    BetaHubRecorder_StartRecording__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_StartRecording: function() {
        if (!BetaHubRecorder.initialized || BetaHubRecorder.isRecording) return;

        BetaHubRecorder.isRecording = true;
        BetaHubRecorder.isPaused = false;
        BetaHubRecorder.segments = [];
        BetaHubRecorder.segmentIndex = 0;
        BetaHubRecorder.stopRequested = false;

        console.log('[BetaHubRecorder] Starting recording with ' + BetaHubRecorder.method);

        if (BetaHubRecorder.method === 'webcodecs') {
            BetaHubRecorder.startWebCodecs();
        } else {
            BetaHubRecorder.startMediaRecorder();
        }
    },

    BetaHubRecorder_StopRecording__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_StopRecording: function() {
        if (!BetaHubRecorder.isRecording) return;

        BetaHubRecorder.stopRequested = true;
        console.log('[BetaHubRecorder] Stop requested');

        if (BetaHubRecorder.method === 'mediarecorder') {
            BetaHubRecorder.stopMediaRecorder();
        }
        // WebCodecs loop will exit on next frame read when it sees stopRequested
    },

    BetaHubRecorder_SetPaused__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_SetPaused: function(paused) {
        BetaHubRecorder.isPaused = !!paused;
        // MediaRecorder supports native pause/resume
        if (BetaHubRecorder.method === 'mediarecorder' && BetaHubRecorder.mrRecorder) {
            if (paused && BetaHubRecorder.mrRecorder.state === 'recording') {
                BetaHubRecorder.mrRecorder.pause();
            } else if (!paused && BetaHubRecorder.mrRecorder.state === 'paused') {
                BetaHubRecorder.mrRecorder.resume();
            }
        }
    },

    BetaHubRecorder_IsRecording__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_IsRecording: function() {
        return BetaHubRecorder.isRecording ? 1 : 0;
    },

    BetaHubRecorder_GetSegmentCount__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_GetSegmentCount: function() {
        return BetaHubRecorder.segments.length;
    },

    BetaHubRecorder_GetSegmentSize__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_GetSegmentSize: function(index) {
        if (index < 0 || index >= BetaHubRecorder.segments.length) return 0;
        return BetaHubRecorder.segments[index].data.byteLength;
    },

    BetaHubRecorder_CopySegmentData__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_CopySegmentData: function(index, destPtr) {
        if (index < 0 || index >= BetaHubRecorder.segments.length) return;
        var segment = BetaHubRecorder.segments[index];
        var srcArray = new Uint8Array(segment.data);
        HEAPU8.set(srcArray, destPtr);
    },

    BetaHubRecorder_GetSegmentMimeType__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_GetSegmentMimeType: function(index) {
        if (index < 0 || index >= BetaHubRecorder.segments.length) return null;
        var mimeType = BetaHubRecorder.segments[index].mimeType;
        var bufferSize = lengthBytesUTF8(mimeType) + 1;
        var buffer = _malloc(bufferSize);
        stringToUTF8(mimeType, buffer, bufferSize);
        return buffer; // IL2CPP runtime auto-frees this after marshaling to string
    },

    BetaHubRecorder_FreeSegments__deps: ['$BetaHubRecorder'],
    BetaHubRecorder_FreeSegments: function() {
        BetaHubRecorder.segments = [];
        console.log('[BetaHubRecorder] Segments freed');
    },
};

mergeInto(LibraryManager.library, BetaHubRecorderLib);
